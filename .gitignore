# Xcode
#
# gitignore contributors: remember to update Global/Xcode.gitignore, Objective-C.gitignore & Swift.gitignore

## User settings
xcuserdata/

## Compatibility with Xcode 8 and earlier (Objective-C or Swift)
*.xcscmblueprint
*.xccheckout

## Compatibility with Xcode 3 and earlier (Objective-C)
*.mode1v3
*.mode2v3
*.perspectivev3
*.pbxuser
!default.pbxuser
*.ppubuild
*.project
*.suo
*.user
*.userdom
*.xcuserdatad/
*.xcodeproj/
!project.pbxproj

## Build products
build/
DerivedData/

## Obj-C/Swift specific
*.hmap

## App packaging
*.ipa
*.dSYM.zip
*.dSYM

## Playgrounds
timeline.xctimeline
playground.xcworkspace

# Swift Package Manager
#
# Add this line if you want to avoid checking in source code from SPM dependencies.
# Packages/
# Package.pins
# Package.resolved
# *.xcodeproj
#
# Xcode generated a single .xcodeproj for this package. Keep it under version control.

# CocoaPods
#
# Recommend not to commit Pods/ directory, but if you do...
# Pods/
#
# Podfile.lock should be committed to ensure consistent pod versions.
Podfile.lock

# Carthage
#
# Carthage builds should not be committed
Carthage/Build/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP/SMB
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Build scripts (if using custom build)
build.sh

# Environment
.env
.env.local

# Logs
*.log

# Temporary files
tmp/
temp/
